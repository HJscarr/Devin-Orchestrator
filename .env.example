# Devin API (required)
DEVIN_API_KEY=cog_your_service_user_key_here
DEVIN_ORG_ID=org-your_org_id_here

# GitHub (required)
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_REPO=YourOrg/YourRepo

# Slack (optional — notifications disabled if omitted)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Devin Playbooks (optional — sessions run without playbooks if omitted)
TRIAGE_PLAYBOOK_ID=playbook-your_triage_playbook_id
FIX_PLAYBOOK_ID=playbook-your_fix_playbook_id
